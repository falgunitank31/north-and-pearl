{
  "sections": {
    "main": {
      "type": "main-product",
      "blocks": {
        "product_note": {
          "type": "text",
          "settings": {
            "text": "Personalized for the name, initial, date, or detail that tells your story.",
            "text_style": "subtitle"
          }
        },
        "title": {
          "type": "title"
        },
        "price": {
          "type": "price"
        },
        "trust_icons": {
          "type": "icon-with-text",
          "settings": {
            "layout": "horizontal",
            "icon_1": "heart",
            "heading_1": "Made meaningful",
            "icon_2": "box",
            "heading_2": "Gift-ready",
            "icon_3": "truck",
            "heading_3": "Free U.S. shipping"
          }
        },
        "shipping_note": {
          "type": "text",
          "settings": {
            "text": "Secure checkout. Review spelling, personalization, and product-specific details carefully before ordering.",
            "text_style": "body"
          }
        },
        "personalization_note": {
          "type": "collapsible_tab",
          "settings": {
            "heading": "Before you personalize",
            "icon": "clipboard",
            "content": "<p>Enter names, initials, dates, coordinates, or gift notes exactly as you want them prepared. Character limits and available options are product-specific.</p>",
            "page": ""
          }
        },
        "variant_picker": {
          "type": "variant_picker",
          "settings": {
            "picker_type": "button",
            "swatch_shape": "circle"
          }
        },
        "quantity_selector": {
          "type": "quantity_selector"
        },
        "buy_buttons": {
          "type": "buy_buttons",
          "settings": {
            "show_dynamic_checkout": false,
            "show_gift_card_recipient": true
          }
        },
        "description": {
          "type": "description"
        },
        "materials": {
          "type": "collapsible_tab",
          "settings": {
            "heading": "Materials",
            "icon": "star",
            "content": "<p>Material details are pending supplier confirmation and owner approval.</p>",
            "page": ""
          }
        },
        "gift_packaging": {
          "type": "collapsible_tab",
          "settings": {
            "heading": "Gift packaging",
            "icon": "box",
            "content": "<p>Built for thoughtful gifting. Packaging options and gift notes may vary by product and should be selected before checkout when available.</p>",
            "page": ""
          }
        },
        "shipping_returns": {
          "type": "collapsible_tab",
          "settings": {
            "heading": "Production, shipping, and returns",
            "icon": "truck",
            "content": "<p>Personalized pieces may require production time before shipping. Custom items are generally final sale unless defective, damaged, or incorrect.</p>",
            "page": ""
          }
        },
        "care": {
          "type": "collapsible_tab",
          "settings": {
            "heading": "Jewelry care",
            "icon": "leaf",
            "content": "<p>Store separately, keep dry when possible, and avoid harsh cleaners. Always follow product-specific care details when listed.</p>",
            "page": ""
          }
        },
        "share": {
          "type": "share",
          "settings": {
            "share_label": "Share"
          }
        }
      },
      "block_order": [
        "product_note",
        "title",
        "price",
        "trust_icons",
        "personalization_note",
        "variant_picker",
        "quantity_selector",
        "buy_buttons",
        "shipping_note",
        "description",
        "materials",
        "gift_packaging",
        "shipping_returns",
        "care",
        "share"
      ],
      "settings": {
        "enable_sticky_info": true,
        "color_scheme": "scheme-1",
        "media_position": "left",
        "gallery_layout": "stacked",
        "media_size": "large",
        "constrain_to_viewport": true,
        "media_fit": "contain",
        "image_zoom": "lightbox",
        "mobile_thumbnails": "hide",
        "hide_variants": true,
        "enable_video_looping": false,
        "padding_top": 36,
        "padding_bottom": 20
      }
    },
    "product_support": {
      "type": "north-pearl-product-support",
      "settings": {
        "kicker": "Personalize with care",
        "heading": "Small details make the gift feel unmistakably theirs.",
        "text": "Check spelling, dates, initials, and gift notes carefully before checkout. Personalized details are prepared from the information entered on the product page.",
        "color_scheme": "scheme-2"
      }
    },
    "related-products": {
      "type": "related-products",
      "settings": {
        "heading": "Complete the gift",
        "heading_size": "h2",
        "products_to_show": 4,
        "columns_desktop": 4,
        "color_scheme": "scheme-2",
        "image_ratio": "square",
        "image_shape": "default",
        "show_secondary_image": true,
        "show_vendor": false,
        "show_rating": false,
        "columns_mobile": "2",
        "padding_top": 48,
        "padding_bottom": 48
      }
    }
  },
  "order": [
    "main",
    "product_support",
    "related-products"
  ]
}
