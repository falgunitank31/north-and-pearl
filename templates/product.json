{
  "sections": {
    "main": {
      "type": "main-product",
      "blocks": {
        "product_note": {
          "type": "text",
          "settings": {
            "text": "Made to celebrate the people, memories, and moments that matter most.",
            "text_style": "subtitle"
          }
        },
        "title": {
          "type": "title"
        },
        "price": {
          "type": "price"
        },
        "trust_icons": {
          "type": "icon-with-text",
          "settings": {
            "layout": "horizontal",
            "icon_1": "box",
            "heading_1": "Gift-ready",
            "icon_2": "heart",
            "heading_2": "Personalized with care",
            "icon_3": "truck",
            "heading_3": "Free U.S. shipping"
          }
        },
        "shipping_note": {
          "type": "text",
          "settings": {
            "text": "Secure checkout. Review personalization, care, and shipping details before placing a time-sensitive gift order.",
            "text_style": "body"
          }
        },
        "variant_picker": {
          "type": "variant_picker",
          "settings": {
            "picker_type": "button",
            "swatch_shape": "circle"
          }
        },
        "quantity_selector": {
          "type": "quantity_selector"
        },
        "buy_buttons": {
          "type": "buy_buttons",
          "settings": {
            "show_dynamic_checkout": false,
            "show_gift_card_recipient": true
          }
        },
        "personalization_note": {
          "type": "collapsible_tab",
          "settings": {
            "heading": "Personalization details",
            "icon": "heart",
            "content": "<p>Enter names, initials, dates, coordinates, or gift notes exactly as you want them prepared. Character limits and available options are product-specific.</p>",
            "page": ""
          }
        },
        "description": {
          "type": "description"
        },
        "materials": {
          "type": "collapsible_tab",
          "settings": {
            "heading": "Materials",
            "icon": "star",
            "content": "<p>Materials can vary by piece and are listed here when confirmed for this product. North & Pearl avoids material and performance claims unless they are verified for the specific item.</p>",
            "page": ""
          }
        },
        "gift_packaging": {
          "type": "collapsible_tab",
          "settings": {
            "heading": "Gift packaging",
            "icon": "box",
            "content": "<p>Designed for meaningful gifting. Packaging options and gift notes may vary by product and should be selected before checkout when available.</p>",
            "page": ""
          }
        },
        "shipping_returns": {
          "type": "collapsible_tab",
          "settings": {
            "heading": "Production, shipping, and returns",
            "icon": "truck",
            "content": "<p>Personalized pieces may require production time before shipping. Custom items are generally final sale unless defective, damaged, or incorrect.</p>",
            "page": ""
          }
        },
        "care": {
          "type": "collapsible_tab",
          "settings": {
            "heading": "Jewelry care",
            "icon": "leaf",
            "content": "<p>Store jewelry separately, keep it dry when possible, and avoid direct contact with lotions, perfumes, and harsh cleaners. Always follow product-specific care details when listed.</p>",
            "page": ""
          }
        },
        "faq": {
          "type": "collapsible_tab",
          "settings": {
            "heading": "Questions before gifting?",
            "icon": "question_mark",
            "content": "<p>For help choosing a piece, review the personalization details, gift notes, care guidance, and shipping information before checkout.</p>",
            "page": ""
          }
        },
        "share": {
          "type": "share",
          "settings": {
            "share_label": "Share"
          }
        }
      },
      "block_order": [
        "product_note",
        "title",
        "price",
        "trust_icons",
        "variant_picker",
        "quantity_selector",
        "buy_buttons",
        "shipping_note",
        "personalization_note",
        "description",
        "materials",
        "gift_packaging",
        "shipping_returns",
        "care",
        "faq",
        "share"
      ],
      "settings": {
        "enable_sticky_info": true,
        "color_scheme": "scheme-1",
        "media_position": "left",
        "gallery_layout": "stacked",
        "media_size": "large",
        "constrain_to_viewport": true,
        "media_fit": "contain",
        "image_zoom": "lightbox",
        "mobile_thumbnails": "hide",
        "hide_variants": true,
        "enable_video_looping": false,
        "padding_top": 36,
        "padding_bottom": 20
      }
    },
    "disclosures": {
      "type": "disclosures",
      "settings": {
        "padding_top": 28,
        "padding_bottom": 0
      }
    },
    "product_support": {
      "type": "north-pearl-product-support",
      "settings": {
        "kicker": "Before you order",
        "heading": "A meaningful piece deserves a careful finish.",
        "text": "Review personalization, gifting, care, and support details before checkout so every piece is prepared with intention.",
        "color_scheme": "scheme-2"
      }
    },
    "related-products": {
      "type": "related-products",
      "settings": {
        "heading": "You may also like",
        "heading_size": "h2",
        "products_to_show": 4,
        "columns_desktop": 4,
        "color_scheme": "scheme-2",
        "image_ratio": "square",
        "image_shape": "default",
        "show_secondary_image": true,
        "show_vendor": false,
        "show_rating": false,
        "columns_mobile": "2",
        "padding_top": 48,
        "padding_bottom": 48
      }
    }
  },
  "order": [
    "main",
    "disclosures",
    "product_support",
    "related-products"
  ]
}
