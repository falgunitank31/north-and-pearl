{
  "sections": {
    "main": {
      "type": "main-product",
      "blocks": {
        "product_note": {
          "type": "text",
          "settings": {
            "text": "Personalized for the name, initial, date, or detail that tells your story.",
            "text_style": "subtitle"
          }
        },
        "title": {
          "type": "title"
        },
        "price": {
          "type": "price"
        },
        "trust_icons": {
          "type": "icon-with-text",
          "settings": {
            "layout": "horizontal",
            "icon_1": "heart",
            "heading_1": "Made meaningful",
            "icon_2": "box",
            "heading_2": "Gift-ready",
            "icon_3": "truck",
            "heading_3": "Free U.S. shipping"
          }
        },
        "shipping_note": {
          "type": "text",
          "settings": {
            "text": "Secure checkout. Final production timelines will be shown before launch.",
            "text_style": "body"
          }
        },
        "personalization_note": {
          "type": "collapsible_tab",
          "settings": {
            "heading": "Before you personalize",
            "icon": "clipboard",
            "content": "<p>Personalization inputs will be configured after product option rules are approved. Confirm spelling, dates, initials, and character limits carefully before ordering.</p>",
            "page": ""
          }
        },
        "variant_picker": {
          "type": "variant_picker",
          "settings": {
            "picker_type": "button",
            "swatch_shape": "circle"
          }
        },
        "quantity_selector": {
          "type": "quantity_selector"
        },
        "buy_buttons": {
          "type": "buy_buttons",
          "settings": {
            "show_dynamic_checkout": true,
            "show_gift_card_recipient": true
          }
        },
        "description": {
          "type": "description"
        },
        "materials": {
          "type": "collapsible_tab",
          "settings": {
            "heading": "Materials",
            "icon": "star",
            "content": "<p>Material details are pending supplier confirmation and owner approval.</p>",
            "page": ""
          }
        },
        "gift_packaging": {
          "type": "collapsible_tab",
          "settings": {
            "heading": "Gift packaging",
            "icon": "box",
            "content": "<p>Built for thoughtful gifting. Final packaging details should be confirmed before launch.</p>",
            "page": ""
          }
        },
        "shipping_returns": {
          "type": "collapsible_tab",
          "settings": {
            "heading": "Production, shipping, and returns",
            "icon": "truck",
            "content": "<p>Production and shipping timelines are pending fulfillment confirmation. Personalized items should generally be non-returnable unless defective, damaged, or incorrect.</p>",
            "page": ""
          }
        },
        "care": {
          "type": "collapsible_tab",
          "settings": {
            "heading": "Jewelry care",
            "icon": "leaf",
            "content": "<p>Store separately and avoid harsh cleaners. Final care instructions must match confirmed materials.</p>",
            "page": ""
          }
        },
        "share": {
          "type": "share",
          "settings": {
            "share_label": "Share"
          }
        }
      },
      "block_order": [
        "product_note",
        "title",
        "price",
        "trust_icons",
        "personalization_note",
        "variant_picker",
        "quantity_selector",
        "buy_buttons",
        "shipping_note",
        "description",
        "materials",
        "gift_packaging",
        "shipping_returns",
        "care",
        "share"
      ],
      "settings": {
        "enable_sticky_info": true,
        "color_scheme": "scheme-1",
        "media_position": "left",
        "gallery_layout": "stacked",
        "media_size": "large",
        "constrain_to_viewport": true,
        "media_fit": "contain",
        "image_zoom": "lightbox",
        "mobile_thumbnails": "hide",
        "hide_variants": true,
        "enable_video_looping": false,
        "padding_top": 36,
        "padding_bottom": 20
      }
    },
    "related-products": {
      "type": "related-products",
      "settings": {
        "heading": "Complete the gift",
        "heading_size": "h1",
        "products_to_show": 4,
        "columns_desktop": 4,
        "color_scheme": "scheme-2",
        "image_ratio": "square",
        "image_shape": "default",
        "show_secondary_image": true,
        "show_vendor": false,
        "show_rating": false,
        "columns_mobile": "2",
        "padding_top": 48,
        "padding_bottom": 48
      }
    }
  },
  "order": [
    "main",
    "related-products"
  ]
}
