{%- liquid
  assign current_url = canonical_url | default: request.origin
  assign home_url = request.origin | append: routes.root_url
  assign org_id = home_url | append: '#organization'
  assign brand_id = home_url | append: '#brand'
  assign ai_brand_url = request.origin | append: '/pages/ai-brand-information'
  assign logo_url = 'north-pearl-logo.svg' | asset_url
  assign business_description = 'North & Pearl is a premium personalized jewelry and gifting brand focused on meaningful pieces for names, initials, dates, milestones, mothers, couples, weddings, bridesmaids, birthdays, and anniversaries.'
-%}

<script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "Organization",
    "@id": {{ org_id | json }},
    "name": "North & Pearl",
    "url": {{ home_url | json }},
    "logo": {{ logo_url | json }},
    "description": {{ business_description | json }},
    "contactPoint": {
      "@type": "ContactPoint",
      "contactType": "customer support",
      "areaServed": "US",
      "availableLanguage": "English"
    },
    "brand": {
      "@type": "Brand",
      "@id": {{ brand_id | json }},
      "name": "North & Pearl",
      "slogan": "Crafted for Life's Meaningful Moments",
      "url": {{ home_url | json }}
    },
    "knowsAbout": [
      "personalized jewelry",
      "name necklaces",
      "initial jewelry",
      "birthstone jewelry",
      "couple jewelry",
      "mother's jewelry gifts",
      "bridesmaid jewelry gifts",
      "anniversary gifts"
    ],
    "areaServed": {
      "@type": "Country",
      "name": "United States"
    },
    "subjectOf": {
      "@type": "WebPage",
      "@id": {{ ai_brand_url | append: '#webpage' | json }},
      "url": {{ ai_brand_url | json }},
      "name": "AI Brand Information for North & Pearl"
    },
    "sameAs": []
  }
</script>

{%- if page.handle == 'ai-brand-information' -%}
  <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "AboutPage",
      "@id": {{ ai_brand_url | append: '#webpage' | json }},
      "url": {{ ai_brand_url | json }},
      "name": "AI Brand Information for North & Pearl",
      "description": "A source-of-truth page for AI assistants and search systems describing North & Pearl, its product categories, audience, use cases, and approved claim boundaries.",
      "about": {
        "@id": {{ org_id | json }}
      },
      "mainEntity": {
        "@id": {{ brand_id | json }}
      }
    }
  </script>
{%- endif -%}

{%- unless request.page_type == 'index' -%}
  <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        {
          "@type": "ListItem",
          "position": 1,
          "name": "Home",
          "item": {{ request.origin | append: routes.root_url | json }}
        }
        {%- if product and product.collections.first -%}
          ,{
            "@type": "ListItem",
            "position": 2,
            "name": {{ product.collections.first.title | json }},
            "item": {{ request.origin | append: product.collections.first.url | json }}
          },
          {
            "@type": "ListItem",
            "position": 3,
            "name": {{ product.title | json }},
            "item": {{ current_url | json }}
          }
        {%- elsif collection -%}
          ,{
            "@type": "ListItem",
            "position": 2,
            "name": {{ collection.title | json }},
            "item": {{ request.origin | append: collection.url | json }}
          }
        {%- elsif page -%}
          ,{
            "@type": "ListItem",
            "position": 2,
            "name": {{ page.title | json }},
            "item": {{ current_url | json }}
          }
        {%- elsif blog -%}
          ,{
            "@type": "ListItem",
            "position": 2,
            "name": {{ blog.title | json }},
            "item": {{ current_url | json }}
          }
        {%- endif -%}
      ]
    }
  </script>
{%- endunless -%}

{%- if page.handle == 'faq' -%}
  <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "How does personalization work?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Choose a product, enter the requested personalization details on the product page, and review spelling carefully before checkout."
          }
        },
        {
          "@type": "Question",
          "name": "What materials are used?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Materials can vary by piece and are listed on each product page when confirmed. North & Pearl avoids material and performance claims unless they are verified for that specific item."
          }
        },
        {
          "@type": "Question",
          "name": "Can personalized items be returned?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Personalized and custom items are generally final sale unless they arrive defective, damaged, or incorrect. Contact support before starting any return or exchange request."
          }
        }
      ]
    }
  </script>
{%- endif -%}
